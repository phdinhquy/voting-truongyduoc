
rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    /* ================= POSTERS ================= */

    match /posters/{posterId} {

      allow read: if true;

      allow update: if request.auth != null;

    }

    /* ================= LOGIN VOTES ================= */

    match /votes/{voteId} {

      allow create: if request.auth != null;

      allow read: if true;

    }

    /* ================= GUEST VOTES ================= */

    match /guest_votes/{deviceId} {

      allow read: if true;

      allow create: if !exists(
        /databases/$(database)/documents/guest_votes/$(deviceId)
      );

      allow update: if false;

      allow delete: if false;

    }

    /* ================= CONFIG ================= */

    match /config/{document=**} {

      allow read: if true;

    }
  }
}
